<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="4dp">

        <!-- Sound profile slot: compact spacer so events sit closer to the icon -->
        <Space
            android:layout_width="42dp"
            android:layout_height="1dp" />

        <!-- Glance carousel: middle zone -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:paddingStart="0dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/glance_dots_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="-3dp"
                android:textColor="#657183"
                android:textSize="7sp"
                android:visibility="gone"
                tools:text="●&#10;○&#10;○"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/glance_carousel_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical|start"
                android:includeFontPadding="false"
                android:maxLines="3"
                android:textAlignment="viewStart"
                android:textColor="#E8EEF7"
                android:textSize="14sp"
                tools:text="📅 Team sync · In 25 min" />
        </LinearLayout>

        <!-- Date + weather: right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/glance_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:ellipsize="end"
                android:gravity="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textAlignment="viewEnd"
                android:textColor="#E8EEF7"
                android:textSize="17sp"
                tools:text="Fri, Mar 28" />

            <TextView
                android:id="@+id/glance_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:gravity="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:textAlignment="viewEnd"
                android:textColor="#9EAAB8"
                android:textSize="13sp"
                tools:text="12° Clear" />
        </LinearLayout>
    </LinearLayout>
</merge>
